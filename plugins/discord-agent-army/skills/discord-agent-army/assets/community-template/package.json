{
  "name": "discord-community-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "doctor": "node --env-file-if-exists=.env src/doctor.mjs",
    "invite": "node --env-file-if-exists=.env src/invite.mjs",
    "provision": "node --env-file-if-exists=.env src/provision.mjs",
    "start": "node --env-file-if-exists=.env src/index.mjs",
    "check": "find src test -name '*.mjs' -print0 | xargs -0 -n1 node --check",
    "test": "npm run check && node --test"
  },
  "dependencies": {
    "discord.js": "^14.26.5",
    "openai": "^6.46.0"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}
