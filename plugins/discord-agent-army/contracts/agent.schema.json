{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/discord-agent-army/agent.schema.json",
  "title": "Discord Agent Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "displayName", "autonomy", "capabilities"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "displayName": { "type": "string", "minLength": 2, "maxLength": 64 },
    "autonomy": { "enum": ["automatic", "approval_required", "recommend_only", "human_only"] },
    "capabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$" } },
    "channels": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
  }
}
